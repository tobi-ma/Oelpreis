# Azure OpenAI / Azure AI — für die KI-Fundamentalanalyse
# Endpoint mit /openai/v1/ am Ende (wie im Azure-Codebeispiel)
AZURE_OPENAI_ENDPOINT=https://dein-resource.openai.azure.com/openai/v1/
AZURE_OPENAI_API_KEY=dein-api-key
AZURE_OPENAI_DEPLOYMENT=dein-deployment-name

# Neon Postgres DB — persistente Speicherung aller Daten
# Pooler-URL verwenden (ep-...-pooler.*.neon.tech)
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.eu-central-1.aws.neon.tech/neondb?sslmode=require
